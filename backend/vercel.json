{
  "buildCommand": "pip install -r requirements.txt",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1",
    "AURASYNC_DATABASE_URL": "@AURASYNC_DATABASE_URL",
    "AURASYNC_CORS_ORIGINS": "https://aurasync-mobile.vercel.app,https://aurasync.vercel.app"
  },
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
