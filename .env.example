# AuraSync — Environment Variables (Development)
# Copy to .env.local and adjust as needed

# Backend (FastAPI + SQLite em dev)
AURASYNC_DATABASE_URL=sqlite:///./backend/aurasync.db
AURASYNC_JWT_SECRET=dev-secret-change-this-in-production-INSECURE
AURASYNC_SEED_ADMIN_PASSWORD=AdminPassword123!

# Backend CORS (dev: permite tudo, prod: restringir)
AURASYNC_CORS_ORIGINS=*

# Admin CMS (Vite, dev)
# Não precisa aqui — use admin/.env.example

# Mobile (Expo, dev)
# Não precisa aqui — use mobile/.env.example

# Futuro: Sentry, SMTP, Email
# SENTRY_DSN=
# SMTP_SERVER=
# SMTP_PORT=587
