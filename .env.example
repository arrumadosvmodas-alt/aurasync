# AuraSync — Environment Variables Template
# Copy to .env and fill with actual values

# Backend Configuration
AURASYNC_DATABASE_URL=sqlite:///./aurasync.db
AURASYNC_JWT_SECRET=dev-secret-change-in-production
AURASYNC_STORAGE_DIR=./storage
AURASYNC_SEED_ADMIN_PASSWORD=TrocarEssaSenha123!

# API Server
API_PORT=8000
API_WORKERS=1
API_LOG_LEVEL=debug

# Frontend URLs
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENV=development

# Monitoring (Optional)
SENTRY_DSN=
DATADOG_API_KEY=

# Email (Optional)
SMTP_SERVER=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# CDN/S3 (Optional)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
